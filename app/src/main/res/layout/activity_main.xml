<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutInputHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Saisir l'en-tête" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutInputBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutInputHeader">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contenu du message" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/actionCommit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/primary_accent"
        android:text="ENREGISTRER"
        app:layout_constraintEnd_toStartOf="@+id/actionClear"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutInputBody" />

    <Button
        android:id="@+id/actionClear"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:backgroundTint="@color/danger"
        android:text="VIDER TOUT"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/actionCommit"
        app:layout_constraintTop_toTopOf="@id/actionCommit" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listRegistry"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/actionCommit" />

</androidx.constraintlayout.widget.ConstraintLayout>
